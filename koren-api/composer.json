{
	"name": "koren/api",
	"description": "Koren eco-marketplace backend API",
	"require": {
		"php": ">=8.1",
		"vine/framework": "*",
		"google/apiclient": "^2.15",
		"firebase/php-jwt": "^6.10",
		"stripe/stripe-php": "^13.0"
	},
	"repositories": [
		{
			"type": "path",
			"url": "./vine-framework"
		}
	],
	"autoload": {
		"psr-4": {
			"App\\": "app/"
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true
}
